# VTEX MCP Servers - Environment Variables
#
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env

# Required: Your VTEX account name
VTEX_ACCOUNT_NAME=your-account-name

# Authentication Option 1: App Key + App Token (recommended)
VTEX_APP_KEY=your-app-key
VTEX_APP_TOKEN=your-app-token

# Authentication Option 2: Auth Token (alternative to App Key/Token)
# VTEX_AUTH_TOKEN=your-auth-token

# Optional: VTEX environment (default: vtexcommercestable)
# VTEX_ENVIRONMENT=vtexcommercestable
