{
  "name": "vtex-mcp-servers",
  "version": "1.0.0",
  "private": true,
  "description": "MCP servers for all public VTEX e-commerce platform APIs",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json,md,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md,yaml}\""
  },
  "keywords": [
    "mcp",
    "vtex",
    "e-commerce",
    "ai"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
